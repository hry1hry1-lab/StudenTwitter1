<div class="password-change-page">
  <div class="page-header">
    <h1>StudenTwitter</h1>
    <h3>パスワードの変更</h3>
  </div>

  <div class="password-form-container">
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "password-card" }) do f | %>
      <%# エラーメッセージ表示エリアも共通の枠に合わせるためのラッパー %>
      <% if resource.errors.any? %>
        <div class="error-explanation-box">
          <%= render "users/shared/error_messages", resource: resource %>
        </div>
      <% end %>
      
      <%= f.hidden_field :reset_password_token %>

      <div class="form-field">
        <%= f.label :password, "新しいパスワード", class: "form-label" %>
        <% if @minimum_password_length %>
          <span class="password-hint">(<%= @minimum_password_length %>文字以上必要です)</span>
        <% end %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "form-input" %>
      </div>

      <div class="form-field">
        <%= f.label :password_confirmation, "新しいパスワード（確認）", class: "form-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input" %>
      </div>

      <div class="form-actions">
        <%= f.submit "パスワードを変更する", class: "password-submit-btn" %>
      </div>
    <% end %>
  </div>

  <div class="page-navigation">
    <%= render "users/shared/links" %>
  </div>
</div>