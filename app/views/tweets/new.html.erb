<div class="form-page-container">
  <div class="page-header">
    <h1>STUDENTWITTER</h1>
    <h3>新規投稿</h3>
  </div>

  <div class="form-card">
    <%= form_for @tweet do |f| %>

      <div class="form-group">
        <%= f.label :title, "タイトル" %>
        <%= f.text_field :title, class: "form-control", placeholder: "タイトルの入力（30文字以内）" %>
      </div>

      <div class="form-group">
        <%= f.label :genre, "ジャンル" %>
        <%= f.select :genre, 
          [["食事編", "食事編"], ["生活編", "生活編"], ["その他", "その他"]], 
          { include_blank: "選択して下さい" }, 
          { class: "form-control select-control" } %>
      </div>

      <div class="form-group">
        <%= f.label :image, "画像添付" %>
        <%= f.file_field :image, class: "form-controlfile" %>
      </div>

      <div class="form-group">
        <%= f.label :contents, "内容" %>
        <%= f.text_area :contents, rows: 4, class: "form-control", placeholder: "投稿内容を入力してください" %>
      </div>

      <div class="form-actions">
        <%= f.submit "投稿する", class: "btn-submit" %>
      </div>
    <% end %>
  </div>

  <div class="page-footer-links">
    <%= link_to "← 一覧に戻る", tweets_path, class: "back-link" %>
  </div>
</div>