  </div>

  <div class="page-header">
    <h1>StudenTwitter</h1>
    <h3>Tweet一覧</h3>
    
    <div class="user-nav">
      <% if user_signed_in? %>
        <span class="nav-user-info">👤 <%= current_user.name %> さんとしてログイン中</span>
        <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete }, class: "logout-link" %>
      <% else %>
        <%= link_to "ログイン", new_user_session_path, class: "login-link" %>
      <% end %>
    </div>
  </div>

  <div class="tweets-container">
    <% @tweets.each do |t| %>
      <div class="tweet-card">
        
        <div class="tweet-main-content">
          <div class="tweet-meta">
            <span class="tweet-user-name">👤 <%= t.user.name %></span>
            <span class="tweet-genre">GENRE: <%= t.respond_to?(:genre) ? t.genre : "共通" %></span>
          </div>

          <h2 class="tweet-title">
            <%= link_to tweet_path(t.id), class: "tweet-title-link" do %>
              TITLE: <%= t.title %>
            <% end %>
          </h2>
          <p class="tweet-body">CONTENTS: <%= t.contents %></p>

          <div class="tweet-actions">
            <% if user_signed_in? %>
              <% if current_user.already_liked?(t) %>
                <%= link_to tweet_like_path(t, current_user.likes.find_by(tweet_id: t.id)), data: { turbo_method: :delete }, class: "like-btn liked" do %>
                  <span>❤️ いいねを取り消す</span>
                <% end %>
                <span class="like-count-display"><%= t.likes.count %></span>
              <% else %>
                <%= link_to tweet_likes_path(t), data: { turbo_method: :post }, class: "like-btn" do %>
                  <span>🤍 いいね</span>
                <% end %>
                <span class="like-count-display"><%= t.likes.count %></span>
              <% end %>
            <% else %>
              <span class="like-status">いいねの数: <%= t.likes.count %></span>
            <% end %>
          </div>

          <div class="tweet-card-navigation">
            <%= link_to "コメントを見る →", tweet_path(t.id), class: "show-link" %>
            <% if user_signed_in? && current_user.id == t.user_id %>
              <%= link_to "編集", edit_tweet_path(t.id), class: "edit-link" %>
              <%= link_to "削除", tweet_path(t.id), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "delete-link" %>
            <% end %>
          </div>
        </div>

        <% if t.image.attached? %>
          <div class="tweet-image">
            <%= image_tag t.image %>
          </div>
        <% end %>

      </div>
    <% end %>
  </div>
</div>